generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  CHEF
  CASHIER
  WAITER
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}

enum OrderStatus {
  PENDING
  PREPARING
  READY
  DELIVERED
  PAID
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum OrderSource {
  CUSTOMER
  STAFF
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  MOBILE_PAYMENT
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum DiscountApprovalStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PrintJobType {
  RECEIPT
  KITCHEN_TICKET
  ORDER_UPDATE_TICKET
  TEST_PAGE
}

enum PrintJobStatus {
  WAITING
  ACTIVE
  COMPLETED
  FAILED
}

enum PrinterType {
  RECEIPT
  KITCHEN
  BAR
}

enum PrinterStatus {
  ONLINE
  OFFLINE
  LOW_PAPER
}

enum ReportType {
  FINANCIAL
  OPERATIONS
  PRINTING
  INVENTORY
  CUSTOMERS
  PAYMENTS
  DISCOUNTS
  FINANCIAL_AUDIT
}

enum ReportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum QueueName {
  PRINTING
  NOTIFICATIONS
  ANALYTICS
  EXPORTS
  BACKUPS
  FAILED_PRINT_JOBS
}

enum QueueJobStatus {
  WAITING
  ACTIVE
  COMPLETED
  FAILED
}

enum QueueJobType {
  PRINT_RECEIPT
  PRINT_KITCHEN_TICKET
  PRINT_ORDER_UPDATE_TICKET
  PRINT_TEST_PAGE
  NOTIFY_ORDER_CREATED
  NOTIFY_ORDER_PREPARING
  NOTIFY_ORDER_READY
  NOTIFY_ORDER_DELIVERED
  NOTIFY_ORDER_PAID
  ANALYTICS_SALES_AGGREGATION
  ANALYTICS_DAILY_METRICS
  ANALYTICS_DASHBOARD_CALCULATION
  EXPORT_SALES_REPORT
  EXPORT_INVENTORY
  EXPORT_CUSTOMERS
  BACKUP_DATABASE
  BACKUP_REPORTS
  BACKUP_SETTINGS
}

enum InventoryStatus {
  HEALTHY
  LOW_STOCK
  CRITICAL
}

enum CustomerTier {
  NEW
  REGULAR
  VIP
}

enum AuditLogStatus {
  SUCCESS
  WARNING
  FAILED
}

enum AuditLogModule {
  ORDERS
  MENU
  SYSTEM
  STAFF
  PRINTING
  INVENTORY
  SETTINGS
  WAITER_NOTIFICATIONS
}

enum WaiterNotificationType {
  CALL_WAITER
  ORDER_READY_FOR_DELIVERY
  ORDER_READY_FOR_PICKUP
}

enum WaiterNotificationStatus {
  PENDING
  ACCEPTED
  RESOLVED
}

model User {
  id                          String               @id @default(uuid()) @db.Uuid
  name                        String
  email                       String               @unique
  password                    String
  role                        UserRole
  phone                       String?
  nationalId                  String?              @unique
  birthDate                   DateTime?
  hireDate                    DateTime?
  address                     String?
  staffCode                   String?              @unique
  pinCode                     String?
  salaryType                  String?              @db.VarChar(16)
  salaryAmount                Float?
  emergencyContactName        String?
  emergencyContactPhone       String?
  notes                       String?
  isActive                    Boolean              @default(true)
  restaurantId                String               @db.Uuid
  restaurant                  Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @updatedAt
  auditLogs                   AuditLog[]
  sessions                    UserSession[]
  acceptedWaiterNotifications WaiterNotification[] @relation("WaiterNotificationAcceptedBy")
  createdPayments             Payment[]            @relation("PaymentCreatedBy")
  updatedPayments             Payment[]            @relation("PaymentUpdatedBy")
  createdDiscounts            Discount[]           @relation("DiscountCreatedBy")
  approvedDiscounts           Discount[]           @relation("DiscountApprovedBy")

  @@index([restaurantId])
  @@map("users")
}

model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  ipAddress        String?   @db.VarChar(64)
  userAgent        String?   @db.VarChar(512)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("user_sessions")
}

model Restaurant {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  address             String
  createdAt           DateTime             @default(now())
  users               User[]
  floors              Floor[]
  tables              Table[]
  menus               Menu[]
  menuItems           MenuItem[]
  modifierGroups      ModifierGroup[]
  orders              Order[]
  printers            PrinterConfig[]
  reports             ReportExportJob[]
  inventoryItems      InventoryItem[]
  customers           CustomerProfile[]
  auditLogs           AuditLog[]
  settings            RestaurantSettings?
  printJobs           PrintJob[]
  queueJobs           QueueJob[]
  failedPrintJobs     FailedPrintJob[]
  waiterNotifications WaiterNotification[]

  @@map("restaurants")
}

model Floor {
  id           String     @id @default(uuid()) @db.Uuid
  name         String
  sortOrder    Int        @default(0)
  restaurantId String     @db.Uuid
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  tables       Table[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@map("floors")
}

model Table {
  id                  String               @id @default(uuid()) @db.Uuid
  number              Int
  capacity            Int
  status              TableStatus          @default(AVAILABLE)
  floorId             String?              @db.Uuid
  posX                Float?
  posY                Float?
  shape               String?              @db.VarChar(16)
  restaurantId        String               @db.Uuid
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  floor               Floor?               @relation(fields: [floorId], references: [id], onDelete: SetNull)
  qrPayload           String
  qrCodeUrl           String
  orders              Order[]
  waiterNotifications WaiterNotification[]
  createdAt           DateTime             @default(now())

  @@unique([restaurantId, number])
  @@index([restaurantId])
  @@index([floorId])
  @@map("tables")
}

model Menu {
  id            String     @id @default(uuid()) @db.Uuid
  name          String
  nameEn        String?
  nameFr        String?
  nameAr        String?
  description   String?
  descriptionEn String?
  descriptionFr String?
  descriptionAr String?
  image         String?
  heroImage     String?
  themeKey      String?    @db.VarChar(64)
  sortOrder     Int        @default(0)
  active        Boolean    @default(true)
  restaurantId  String     @db.Uuid
  restaurant    Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items         MenuItem[]

  @@index([restaurantId])
  @@map("menus")
}

model MenuItem {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  nameEn         String?
  nameFr         String?
  nameAr         String?
  description    String?
  descriptionEn  String?
  descriptionFr  String?
  descriptionAr  String?
  price          Float
  image          String?
  available      Boolean         @default(true)
  featured       Boolean         @default(false)
  badge          String?
  badgeEn        String?
  badgeFr        String?
  badgeAr        String?
  sortOrder      Int             @default(0)
  menuId         String          @db.Uuid
  menu           Menu            @relation(fields: [menuId], references: [id], onDelete: Cascade)
  restaurantId   String          @db.Uuid
  restaurant     Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems     OrderItem[]
  modifierGroups ModifierGroup[]

  @@index([restaurantId])
  @@index([menuId])
  @@map("menu_items")
}

model ModifierGroup {
  id            String           @id @default(uuid()) @db.Uuid
  name          String
  nameEn        String?
  nameFr        String?
  nameAr        String?
  description   String?
  descriptionEn String?
  descriptionFr String?
  descriptionAr String?
  required      Boolean          @default(false)
  minSelections Int              @default(0)
  maxSelections Int              @default(1)
  sortOrder     Int              @default(0)
  restaurantId  String           @db.Uuid
  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItemId    String           @db.Uuid
  menuItem      MenuItem         @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  options       ModifierOption[]

  @@index([restaurantId])
  @@index([menuItemId])
  @@map("modifier_groups")
}

model ModifierOption {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  nameEn        String?
  nameFr        String?
  nameAr        String?
  description   String?
  descriptionEn String?
  descriptionFr String?
  descriptionAr String?
  priceDelta    Float               @default(0)
  available     Boolean             @default(true)
  isDefault     Boolean             @default(false)
  sortOrder     Int                 @default(0)
  groupId       String              @db.Uuid
  group         ModifierGroup       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  selections    OrderItemModifier[]

  @@index([groupId])
  @@map("modifier_options")
}

model Order {
  id                  String               @id @default(uuid()) @db.Uuid
  status              OrderStatus          @default(PENDING)
  orderType           OrderType            @default(DINE_IN)
  source              OrderSource          @default(CUSTOMER)
  total               Float
  businessDate        DateTime             @db.Date
  dailyOrderNumber    Int
  tableId             String?              @db.Uuid
  parentOrderId       String?              @db.Uuid
  restaurantId        String               @db.Uuid
  guestSessionId      String?
  version             Int                  @default(1)
  lockedAt            DateTime?
  preparationStartedAt DateTime?
  readyAt             DateTime?
  deliveredAt         DateTime?
  table               Table?               @relation(fields: [tableId], references: [id], onDelete: Restrict)
  parentOrder         Order?               @relation("OrderAdditions", fields: [parentOrderId], references: [id], onDelete: SetNull)
  childOrders         Order[]              @relation("OrderAdditions")
  restaurant          Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items               OrderItem[]
  payments            Payment[]
  discounts           Discount[]
  printJobs           PrintJob[]
  waiterNotifications WaiterNotification[]
  createdAt           DateTime             @default(now())
  lastModifiedAt      DateTime             @updatedAt

  @@unique([restaurantId, businessDate, dailyOrderNumber])
  @@index([restaurantId])
  @@index([tableId])
  @@index([guestSessionId])
  @@index([restaurantId, tableId])
  @@index([parentOrderId])
  @@map("orders")
}

model OrderItem {
  id         String              @id @default(uuid()) @db.Uuid
  quantity   Int
  price      Float
  notes      String?
  orderId    String              @db.Uuid
  menuItemId String              @db.Uuid
  order      Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem   MenuItem            @relation(fields: [menuItemId], references: [id], onDelete: Restrict)
  modifiers  OrderItemModifier[]

  @@index([orderId])
  @@index([menuItemId])
  @@map("order_items")
}

model OrderItemModifier {
  id               String          @id @default(uuid()) @db.Uuid
  orderItemId      String          @db.Uuid
  modifierOptionId String?         @db.Uuid
  groupName        String
  groupNameEn      String?
  groupNameFr      String?
  groupNameAr      String?
  optionName       String
  optionNameEn     String?
  optionNameFr     String?
  optionNameAr     String?
  priceDelta       Float           @default(0)
  orderItem        OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierOption   ModifierOption? @relation(fields: [modifierOptionId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([modifierOptionId])
  @@map("order_item_modifiers")
}

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @db.Uuid
  amount          Float
  paymentMethod   PaymentMethod
  status          PaymentStatus @default(PENDING)
  referenceNumber String?
  notes           String?
  reason          String?
  refundedAmount  Float         @default(0)
  remainingAmount Float         @default(0)
  createdBy       String?       @db.Uuid
  updatedBy       String?       @db.Uuid
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdByUser   User?         @relation("PaymentCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  updatedByUser   User?         @relation("PaymentUpdatedBy", fields: [updatedBy], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("payments")
}

model Discount {
  id             String                 @id @default(uuid()) @db.Uuid
  orderId        String                 @db.Uuid
  type           DiscountType
  value          Float
  reason         String
  approvalStatus DiscountApprovalStatus @default(PENDING_APPROVAL)
  approvedBy     String?                @db.Uuid
  createdBy      String?                @db.Uuid
  createdAt      DateTime               @default(now())
  order          Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  approvedByUser User?                  @relation("DiscountApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  createdByUser  User?                  @relation("DiscountCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([approvalStatus])
  @@map("discounts")
}

model PrintJob {
  id           String          @id @default(uuid()) @db.Uuid
  jobId        String?         @unique @db.VarChar(191)
  orderId      String?         @db.Uuid
  restaurantId String?         @db.Uuid
  printerId    String?         @db.Uuid
  queueJobId   String?         @unique @db.Uuid
  type         PrintJobType
  printerName  String
  status       PrintJobStatus  @default(WAITING)
  attempts     Int             @default(0)
  payload      Json?
  result       Json?
  failedReason String?
  errorMessage String?
  processedAt  DateTime?
  printedAt    DateTime?
  createdAt    DateTime        @default(now())
  order        Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)
  restaurant   Restaurant?     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  printer      PrinterConfig?  @relation(fields: [printerId], references: [id], onDelete: SetNull)
  queueJob     QueueJob?       @relation(fields: [queueJobId], references: [id], onDelete: SetNull)
  failedJob    FailedPrintJob?

  @@index([orderId])
  @@index([restaurantId])
  @@index([printerId])
  @@index([status])
  @@index([type])
  @@map("print_jobs")
}

model PrinterConfig {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  ipAddress    String
  port         Int
  type         PrinterType
  status       PrinterStatus    @default(ONLINE)
  restaurantId String           @db.Uuid
  restaurant   Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  printJobs    PrintJob[]
  failedJobs   FailedPrintJob[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([restaurantId])
  @@index([type])
  @@map("printer_configs")
}

model ReportExportJob {
  id           String       @id @default(uuid()) @db.Uuid
  restaurantId String       @db.Uuid
  queueJobId   String?      @unique @db.Uuid
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  type         ReportType
  name         String
  status       ReportStatus @default(PENDING)
  format       String
  filePath     String?
  errorMessage String?
  rangeStart   DateTime
  rangeEnd     DateTime
  rowCount     Int          @default(0)
  startedAt    DateTime?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?
  failedAt     DateTime?
  queueJob     QueueJob?    @relation(fields: [queueJobId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
  @@index([type])
  @@index([status])
  @@map("report_export_jobs")
}

model InventoryItem {
  id            String          @id @default(uuid()) @db.Uuid
  restaurantId  String          @db.Uuid
  restaurant    Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name          String
  unit          String
  stockLevel    Float
  minAlertLevel Float
  unitPrice     Float
  supplier      String
  status        InventoryStatus @default(HEALTHY)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([restaurantId])
  @@index([status])
  @@map("inventory_items")
}

model CustomerProfile {
  id           String       @id @default(uuid()) @db.Uuid
  restaurantId String       @db.Uuid
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  name         String
  phone        String
  email        String?
  tier         CustomerTier @default(NEW)
  notes        String?
  totalOrders  Int          @default(0)
  totalSpent   Float        @default(0)
  lastVisitAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([restaurantId])
  @@index([tier])
  @@map("customer_profiles")
}

model AuditLog {
  id           String         @id @default(uuid()) @db.Uuid
  restaurantId String         @db.Uuid
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  userId       String?        @db.Uuid
  user         User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  userName     String
  role         String
  action       String
  details      Json?
  module       AuditLogModule
  status       AuditLogStatus
  createdAt    DateTime       @default(now())

  @@index([restaurantId])
  @@index([module])
  @@index([status])
  @@map("audit_logs")
}

model QueueJob {
  id              String           @id @default(uuid()) @db.Uuid
  bullJobId       String           @unique @db.VarChar(191)
  queueName       QueueName
  jobType         QueueJobType
  restaurantId    String?          @db.Uuid
  status          QueueJobStatus   @default(WAITING)
  attempts        Int              @default(0)
  maxAttempts     Int              @default(3)
  payload         Json
  result          Json?
  error           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  processedAt     DateTime?
  failedAt        DateTime?
  restaurant      Restaurant?      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  printJob        PrintJob?
  reportExportJob ReportExportJob?
  failedPrintJob  FailedPrintJob?

  @@index([queueName])
  @@index([jobType])
  @@index([restaurantId])
  @@index([status])
  @@map("queue_jobs")
}

model FailedPrintJob {
  id           String         @id @default(uuid()) @db.Uuid
  queueJobId   String         @unique @db.Uuid
  printJobId   String?        @unique @db.Uuid
  printerId    String?        @db.Uuid
  jobId        String         @db.VarChar(191)
  restaurantId String         @db.Uuid
  payload      Json
  error        String
  attempts     Int
  failedAt     DateTime       @default(now())
  queueJob     QueueJob       @relation(fields: [queueJobId], references: [id], onDelete: Cascade)
  printJob     PrintJob?      @relation(fields: [printJobId], references: [id], onDelete: SetNull)
  printer      PrinterConfig? @relation(fields: [printerId], references: [id], onDelete: SetNull)
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([printerId])
  @@index([restaurantId])
  @@index([failedAt])
  @@map("failed_print_jobs")
}

model RestaurantSettings {
  id                     String     @id @default(uuid()) @db.Uuid
  restaurantId           String     @unique @db.Uuid
  restaurant             Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantName         String
  contactPhone           String
  contactEmail           String?
  businessAddress        String
  receiptLogoUrl         String?
  receiptFooterMessage   String?
  openingHours           String
  closingHours           String
  currency               String
  salesTax               Float      @default(0)
  defaultDiscountLabel   String?
  maxAutoDiscountPercent Float      @default(10)
  refundAlertThreshold   Float      @default(10000)
  language               String     @default("en")
  direction              String     @default("ltr")
  locale                 String     @default("en-US")
  dateFormat             String     @default("dd/MM/yyyy")
  acceptsCash            Boolean    @default(true)
  acceptsCard            Boolean    @default(true)
  acceptsQrOrdering      Boolean    @default(true)
  stripeEnabled          Boolean    @default(false)
  whatsappEnabled        Boolean    @default(false)
  smtpEnabled            Boolean    @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@map("restaurant_settings")
}

model WaiterNotification {
  id               String                   @id @default(uuid()) @db.Uuid
  restaurantId     String                   @db.Uuid
  tableId          String?                  @db.Uuid
  orderId          String?                  @db.Uuid
  acceptedByUserId String?                  @db.Uuid
  type             WaiterNotificationType
  status           WaiterNotificationStatus @default(PENDING)
  message          String
  metadata         Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  acceptedAt       DateTime?
  resolvedAt       DateTime?
  restaurant       Restaurant               @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  table            Table?                   @relation(fields: [tableId], references: [id], onDelete: Cascade)
  order            Order?                   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  acceptedByUser   User?                    @relation("WaiterNotificationAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([restaurantId, status, createdAt])
  @@index([tableId, status])
  @@index([orderId])
  @@index([acceptedByUserId])
  @@map("waiter_notifications")
}
