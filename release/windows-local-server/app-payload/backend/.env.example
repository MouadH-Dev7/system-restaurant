NODE_ENV=development
HOST=0.0.0.0
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/restaurant_db
# Docker maps postgres to host port 5433 (5432 is often used by local PostgreSQL on Windows)
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-change-me-change-me-1234
JWT_REFRESH_SECRET=change-me-change-me-refresh-1234
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://192.168.100.6,http://192.168.100.6:3001,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost
CUSTOMER_APP_URL=http://192.168.100.6
